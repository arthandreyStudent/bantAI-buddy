{
  "manifest_version": 3,
  "name": "BantAI Buddy",
  "version": "1.0.0",
  "description": "AI-powered protection for children that analyzes your Messenger locally to detect potentially harmful content, without sending any data outside your browser.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.messenger.com/*",
    "https://messenger.com/*",
    "https://www.facebook.com/*",
    "https://www.instagram.com/*",
    "https://*.openai.azure.com/*",
    "https://bantaivercel.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.messenger.com/*",
        "https://messenger.com/*",
        "https://www.facebook.com/*",
        "https://*.facebook.com/*",
        "https://www.instagram.com/*"
      ],
      "js": [
        "content-scripts/messenger-dom.js",
        "content-scripts/application-observer.js",
        "content-scripts/conversation-observer.js",
        "content-scripts/cache-manager.js",
        "content-scripts/message-processor.js",
        "content-scripts/blur-manager.js",
        "content-scripts/popup-manager.js",
        "content-scripts/content-script.js"
      ],
      "css": ["assets/guard-styles.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "ui/view/popup.html",
    "default_title": "BantAI Buddy",
    "default_icon": {
      "16": "assets/final_icon-16.png",
      "32": "assets/final_icon-32.png"
    }
  },
  "icons": {
    "16": "assets/final_icon-16.png",
    "48": "assets/final_icon-48.png",
    "128": "assets/final_icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/uhoh.png", 
        "assets/final_icon.png", 
        "assets/final_icon-16.png", 
        "assets/final_icon-32.png", 
        "assets/final_icon-48.png", 
        "assets/final_icon-128.png", 
        "assets/bAI.png", 
        "assets/bAI_2.png", 
        "assets/bAI_3.png", 
        "assets/bAI_4.png"
      ],
      "matches": [
        "https://www.messenger.com/*",
        "https://messenger.com/*",
        "https://www.facebook.com/*",
        "https://*.facebook.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
